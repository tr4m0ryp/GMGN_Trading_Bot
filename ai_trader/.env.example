# AI Trader Configuration
# Copy this file to .env and fill in your values

# ===== TRADING MODE =====
# true = Paper trading (simulated, no real money)
# false = Live trading with Jito Bundle (REAL MONEY - USE WITH CAUTION)
PAPERTRADE=true

# ===== WALLET CONFIGURATION =====
# Private key in base58 format (KEEP SECRET! Used for live trading only)
WALLET_PRIVATE_KEY=

# ===== MODEL CONFIGURATION =====
# Path to models directory (relative to ai_trader/)
# Place your model.zip file in this directory
MODEL_DIR=models

# ===== POSITION SETTINGS =====
# Amount of SOL to invest per trade
TRADE_AMOUNT_SOL=0.01

# Maximum concurrent positions per token
MAX_POSITIONS=5

# ===== PAPER TRADING SETTINGS =====
# Initial simulated wallet balance (SOL)
PAPER_WALLET_BALANCE=1.0

# ===== TAKE PROFIT / STOP LOSS =====
# Take profit percentage (0.30 = 30%)
TAKE_PROFIT_PCT=0.30
# Stop loss percentage (0.08 = 8%)
STOP_LOSS_PCT=0.08

# ===== API SETTINGS =====
# GMGN cookies for API access (get from browser dev tools)
GMGN_CF_CLEARANCE=
GMGN_CF_BM=
GMGN_GA=
GMGN_GA_SESSION=

# ===== JITO SETTINGS (Live Mode Only) =====
# Jito block engine endpoint
JITO_ENDPOINT=https://amsterdam.mainnet.block-engine.jito.wtf
# Tip in lamports (50000 = 0.00005 SOL)
JITO_TIP_LAMPORTS=50000

# ===== TELEGRAM BOT SETTINGS =====
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=
# Enable trade notifications (true/false)
TELEGRAM_NOTIFY_TRADES=true
# Enable error notifications (true/false)
TELEGRAM_NOTIFY_ERRORS=true
